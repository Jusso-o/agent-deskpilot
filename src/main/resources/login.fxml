<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.deskpilot.agent.ui.LoginController"
      prefWidth="340" prefHeight="560"
      styleClass="root-pane"
      stylesheets="@style.css">

    <HBox styleClass="titlebar" alignment="CENTER_LEFT" spacing="10">
        <HBox spacing="6">
            <Label styleClass="dot dot-red"/>
            <Label styleClass="dot dot-yellow"/>
            <Label styleClass="dot dot-green"/>
        </HBox>
        <Label text="DeskPilot Agent" styleClass="titlebar-text" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="4">
            <Button text="—" styleClass="titlebar-btn" onAction="#onMinimize"/>
            <Button text="✕" styleClass="titlebar-btn-close" onAction="#onClose"/>
        </HBox>
    </HBox>

    <VBox styleClass="body" spacing="0" VBox.vgrow="ALWAYS">

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="logo-row">
            <Label styleClass="logo-icon" text="⬡"/>
            <VBox>
                <Label text="DeskPilot" styleClass="logo-title"/>
                <Label text="Controle remoto seguro" styleClass="logo-sub"/>
            </VBox>
        </HBox>

        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
            <Label fx:id="statusDot" styleClass="status-dot-red"/>
            <Label fx:id="statusText" text="Desconectado" styleClass="status-text"/>
        </HBox>

        <Label text="URL do relay" styleClass="form-label"/>
        <TextField fx:id="relayUrlField" promptText="ws://localhost:8080/relay"/>

        <Label text="Usuário" styleClass="form-label"/>
        <TextField fx:id="usernameField" promptText="seu usuário"/>

        <Label text="Senha" styleClass="form-label"/>
        <PasswordField fx:id="passwordField" promptText="••••••••"/>

        <Button fx:id="connectBtn" text="Conectar" styleClass="btn-primary"
                onAction="#onConnect" maxWidth="Infinity">
            <VBox.margin><Insets top="20"/></VBox.margin>
        </Button>

        <Separator styleClass="divider">
            <VBox.margin><Insets top="16" bottom="4"/></VBox.margin>
        </Separator>

        <Label text="Configurações de stream" styleClass="section-title"/>

        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="slider-row">
            <Label text="FPS" styleClass="slider-label" minWidth="60"/>
            <Slider fx:id="fpsSlider" min="10" max="60" value="24"
                    blockIncrement="1" HBox.hgrow="ALWAYS"/>
            <Label fx:id="fpsValue" text="24" styleClass="slider-val" minWidth="36"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="slider-row">
            <Label text="Qualidade" styleClass="slider-label" minWidth="60"/>
            <Slider fx:id="qualitySlider" min="10" max="100" value="60"
                    blockIncrement="1" HBox.hgrow="ALWAYS"/>
            <Label fx:id="qualityValue" text="60%" styleClass="slider-val" minWidth="36"/>
        </HBox>

        <Label text="Minimizar fecha para a bandeja do sistema" styleClass="tray-note"/>

    </VBox>
</VBox>